generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Admin {
  adminId      BigInt @id @default(autoincrement()) @map("admin_id")
  email        String @unique
  displayName  String @map("display_name")
  passwordHash String @map("password_hash")

  // 1対多の「多」側（外部キーを持つ側）
  // onDelete: Restrict … ステータスに紐づく管理者がいると削除不可
  statusId          Int         @map("status_id")
  adminStatus       AdminStatus @relation(fields: [statusId], references: [statusId], onDelete: Restrict, onUpdate: Cascade)
  otpCode           String?     @map("otp_code")
  otpExpiredAt      DateTime?   @map("otp_expired_at") @db.Timestamptz
  otpFailureCount   Int         @default(0) @map("otp_failure_count")
  loginFailureCount Int         @default(0) @map("login_failure_count")
  lastLoginFailedAt DateTime?   @map("last_login_failed_at") @db.Timestamptz
  lastLoginAt       DateTime?   @map("last_login_at") @db.Timestamptz
  isDeleted         Int         @default(0) @map("is_deleted")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@index([displayName])
  @@index([statusId]) //status_idによる検索が多い想定
  @@map("admins")
}

model AdminStatus {
  statusId  Int      @id @map("status_id")
  status    String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // 1対多の「1」側（関連先は複数＝配列）
  admins Admin[]

  @@map("admin_statuses")
}

model AdminLoginLog {
  logId     BigInt   @id @default(autoincrement()) @map("log_id")
  adminId   BigInt?  @map("admin_id")
  email     String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  status    Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([adminId])
  @@index([email])
  @@index([ipAddress])
  @@map("Admin_login_logs")
}
